# =============================================================================
# ObjectPoolSystem — Required Environment Variables
# =============================================================================
# Copy this file to .env (git-ignored) and fill in your real values,
# OR set these directly in your OS / CI pipeline / Docker compose file.
#
# .NET reads environment variables automatically using __ as the section
# separator, so these map directly to appsettings.json keys:
#
#   ConnectionStrings__DefaultConnection  →  ConnectionStrings:DefaultConnection
#   Email__Username                       →  Email:Username
#   Email__Password                       →  Email:Password
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Full Npgsql connection string.
# Example: Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=secret;Pooling=false
ConnectionStrings__DefaultConnection=

# ---------------------------------------------------------------------------
# Email (SMTP / Gmail)
# ---------------------------------------------------------------------------
# Gmail address used as the sender.
Email__Username=

# Gmail App Password (NOT your Google account password).
# Generate one at: https://myaccount.google.com/apppasswords
Email__Password=
